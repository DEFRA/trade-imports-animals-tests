{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@domain/*": ["domain/*"],
      "@page-objects": ["ui/page-objects"],
      "@page-objects/*": ["ui/page-objects/*"],
      "@flows/*": ["ui/flows/*"],
      "@fixtures": ["fixtures"],
      "@utils/*": ["utils/*"]
    }
  }
}
